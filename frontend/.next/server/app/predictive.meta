{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/predictive/layout,_N_T_/predictive/page,_N_T_/predictive"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/predictive/__PAGE__",
    "/predictive",
    "/_index",
    "/_head"
  ]
}