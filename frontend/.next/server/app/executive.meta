{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/executive/layout,_N_T_/executive/page,_N_T_/executive"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/executive/__PAGE__",
    "/executive",
    "/_index",
    "/_head"
  ]
}